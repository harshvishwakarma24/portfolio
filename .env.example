# Portfolio Contact Form Configuration
# IMPORTANT: Never commit actual secrets to .env - use .env.local for development
# Production secrets should be set via environment variables on your hosting platform

# Contact Form Email (recipient email)
VITE_CONTACT_EMAIL=harshp24vishwakarma@gmail.com

# Redirect URL after successful form submission
VITE_FORM_REDIRECT_URL=/

# Form Submission Settings
VITE_FORM_SERVICE_URL=https://formsubmit.co

# Rate Limiting Settings (in milliseconds)
VITE_FORM_RATE_LIMIT_MS=3000
VITE_FORM_MAX_SUBMISSIONS_PER_HOUR=10

# Security Settings
VITE_ENABLE_FORM_VALIDATION=true
VITE_ENABLE_BOT_DETECTION=true
VITE_CSRF_TOKEN_ENABLED=true

# Error Reporting (set to false in development)
VITE_SEND_ERROR_REPORTS=false
